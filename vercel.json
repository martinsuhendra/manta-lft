{
  "buildCommand": "prisma generate && next build",
  "crons": [
    {
      "path": "/api/cron/expire-memberships",
      "schedule": "0 17 * * *"
    },
    {
      "path": "/api/cron/reactivate-frozen-memberships",
      "schedule": "5 17 * * *"
    }
  ],
  "functions": {
    "app/api/**/*.ts": {
      "maxDuration": 10
    }
  }
}
